# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
._*
*.pem

# trace / perf files
*.json.gz

# agent / IDE metadata
.agents/
.trae/
skills-lock.json
AGENTS.md

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# datos de presupuestos (generados en runtime)
/data/presupuestos.json
/data/presupuestos.json.tmp

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
